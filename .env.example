# Copy this file to .env and fill in your values
# (or set these as environment variables on your hosting provider)

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=TELEGRAM_BOT_TOKEN

# The ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=GOOGLE_SHEET_ID

# Option A (recommended for cloud hosting):
#   Paste the entire contents of your credentials.json as a single-line JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=GOOGLE_SERVICE_ACCOUNT_JSON


# Option B (for local/server hosting):
#   Leave GOOGLE_SERVICE_ACCOUNT_JSON unset and place your credentials.json
#   file in the same folder as bot.py


Key=Key
Value=Value